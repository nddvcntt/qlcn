# Production environment template
# Copy to .env.production and fill in real values

# === Database (PostgreSQL) ===
# Example: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL="postgresql://qlcn_user:CHANGE_ME@postgres:5432/qlcn_prod?schema=public"

# === NextAuth ===
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32"
NEXTAUTH_URL="https://your-domain.com"

# === App ===
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NODE_ENV="production"
