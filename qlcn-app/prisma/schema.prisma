// QLCN - Hệ Thống Quản Lý Cơm Nắm
// Database Schema - PostgreSQL (Production)
// Dùng cho: Neon.tech, Vercel Postgres, Supabase, self-hosted Docker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ORGANIZATION ====================

model Organization {
  id        String   @id @default(uuid())
  name      String
  logo      String?
  address   String?
  phone     String?
  taxCode   String?  @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]

  @@map("organizations")
}

// ==================== BRANCH ====================

model Branch {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String       @unique
  address        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  departments   Department[]
  sellingPoints SellingPoint[]
  users         User[]
  products      Product[]
  importOrders  ImportOrder[]
  exportOrders  ExportOrder[]
  inventory     Inventory[]
  production    DailyProduction[]
  salaryRecords SalaryRecord[]
  costRecords   CostRecord[]
  workSchedules WorkSchedule[]
  shifts        Shift[]

  @@index([organizationId, isActive])
  @@map("branches")
}

// ==================== DEPARTMENTS ====================

model Department {
  id        String  @id @default(uuid())
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  code      String
  managerId String?
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id])
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("departments")
}

// ==================== SHIFT (CA LÀM VIỆC) ====================

model Shift {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code        String
  name        String
  startTime   String   // "06:00"
  endTime     String   // "14:00"
  salaryRate  Decimal  @default(70000) @db.Decimal(15, 2)
  bonusPerUnit Decimal @default(500) @db.Decimal(15, 2)
  bonusThreshold Int    @default(50)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workSchedules    WorkSchedule[]
  dailyProductions DailyProduction[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("shifts")
}

// ==================== SELLING POINTS ====================

model SellingPoint {
  id             String   @id @default(uuid())
  branchId       String
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name           String
  code           String
  address        String?
  group          String   @default("GROUP_2")
  salaryPerShift Decimal  @default(70000) @db.Decimal(15, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workSchedules WorkSchedule[]
  productions   DailyProduction[]
  exportOrders  ExportOrder[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("selling_points")
}

// ==================== USERS ====================

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  password     String
  fullName     String
  email        String   @unique
  phone        String?
  role         String
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean  @default(true)
  startDate    DateTime? @default(now())
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedDepartments     Department[]       @relation("DepartmentManager")
  createdImportOrders    ImportOrder[]      @relation("ImportOrderCreator")
  createdExportOrders    ExportOrder[]      @relation("ExportOrderCreator")
  productions            DailyProduction[]  @relation("EmployeeProduction")
  approvedProductions    DailyProduction[]  @relation("ProductionApprover")
  salaryRecords          SalaryRecord[]     @relation("EmployeeSalary")
  approvedByBranch       SalaryRecord[]     @relation("SalaryApproverBranch")
  approvedByOrg          SalaryRecord[]     @relation("SalaryApproverOrg")
  salaryAdjustments      SalaryAdjustment[]
  workSchedules          WorkSchedule[]     @relation("ScheduleEmployee")
  approvedWorkSchedules  WorkSchedule[]     @relation("ScheduleApprover")
  costRecords            CostRecord[]
  auditLogs              AuditLog[]
  priceHistory           PriceHistory[]

  @@index([branchId, isActive])
  @@index([role])
  @@map("users")
}

// ==================== PRODUCTS ====================

model Product {
  id           String  @id @default(uuid())
  branchId     String?
  branch       Branch? @relation(fields: [branchId], references: [id])
  name         String
  code         String  @unique
  costPrice    Decimal @db.Decimal(15, 2)
  sellingPrice Decimal @db.Decimal(15, 2)
  unit         String  @default("nắm")
  image        String?
  type         String  @default("COM_NAM")
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bonusThreshold Int     @default(50)
  bonusPerUnit   Decimal @default(500) @db.Decimal(15, 2)
  commissionRate Decimal @default(0) @db.Decimal(5, 2)

  importItems  ImportOrderItem[]
  exportItems  ExportOrderItem[]
  inventory    Inventory[]
  priceHistory PriceHistory[]

  @@index([branchId, isActive])
  @@index([type])
  @@map("products")
}

// ==================== IMPORT ORDERS ====================

model ImportOrder {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  importDate  DateTime
  totalAmount Decimal  @default(0) @db.Decimal(18, 2)
  note        String?
  createdById String
  createdBy   User     @relation("ImportOrderCreator", fields: [createdById], references: [id])
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ImportOrderItem[]

  @@index([branchId, importDate(sort: Desc)])
  @@index([status])
  @@index([createdById, createdAt(sort: Desc)])
  @@map("import_orders")
}

model ImportOrderItem {
  id             String      @id @default(uuid())
  importOrderId  String
  importOrder    ImportOrder @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  quantity       Int
  giftedQuantity Int         @default(0)
  unitPrice      Decimal     @db.Decimal(15, 2)
  totalAmount    Decimal     @db.Decimal(18, 2)

  @@index([importOrderId])
  @@index([productId])
  @@map("import_order_items")
}

// ==================== EXPORT ORDERS ====================

model ExportOrder {
  id             String       @id @default(uuid())
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sellingPointId String
  sellingPoint   SellingPoint @relation(fields: [sellingPointId], references: [id])
  exportDate     DateTime
  totalRevenue   Decimal      @default(0) @db.Decimal(18, 2)
  totalDiscount  Decimal      @default(0) @db.Decimal(18, 2)
  note           String?
  createdById    String
  createdBy      User         @relation("ExportOrderCreator", fields: [createdById], references: [id])
  status         String       @default("DRAFT")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items ExportOrderItem[]

  @@index([branchId, sellingPointId, exportDate(sort: Desc)])
  @@index([exportDate(sort: Desc)])
  @@index([status])
  @@map("export_orders")
}

model ExportOrderItem {
  id               String      @id @default(uuid())
  exportOrderId    String
  exportOrder      ExportOrder @relation(fields: [exportOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product     @relation(fields: [productId], references: [id])
  quantity         Int
  giftedQuantity   Int         @default(0)
  unitPrice        Decimal     @db.Decimal(15, 2)
  discountAmount   Decimal     @default(0) @db.Decimal(15, 2)
  totalAmount      Decimal     @db.Decimal(18, 2)
  bonusExcluded    Boolean     @default(false)

  @@index([exportOrderId])
  @@index([productId])
  @@map("export_order_items")
}

// ==================== INVENTORY ====================

model Inventory {
  id             String   @id @default(uuid())
  branchId       String
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  date           DateTime @db.Date
  openingStock   Int      @default(0)
  importQuantity Int      @default(0)
  exportQuantity Int      @default(0)
  giftedQuantity Int      @default(0)
  closingStock   Int
  updatedAt      DateTime @updatedAt

  @@unique([branchId, productId, date])
  @@index([branchId, date(sort: Desc)])
  @@index([productId, date(sort: Desc)])
  @@map("inventory")
}

// ==================== WORK SCHEDULE ====================

model WorkSchedule {
  id             String       @id @default(uuid())
  employeeId     String
  employee       User         @relation("ScheduleEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sellingPointId String
  sellingPoint   SellingPoint @relation(fields: [sellingPointId], references: [id])
  shiftId        String?
  shift          Shift?       @relation(fields: [shiftId], references: [id])
  shiftCode      String       @default("SANG") // legacy/compat
  workDate       DateTime     @db.Date
  status         String       @default("PENDING")
  approvedById   String?
  approvedBy     User?        @relation("ScheduleApprover", fields: [approvedById], references: [id])
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  production DailyProduction?

  @@unique([employeeId, workDate, shiftId])
  @@index([branchId, workDate(sort: Desc)])
  @@index([sellingPointId, workDate(sort: Desc)])
  @@index([status])
  @@index([employeeId, workDate(sort: Desc)])
  @@map("work_schedules")
}

// ==================== DAILY PRODUCTION ====================

model DailyProduction {
  id             String       @id @default(uuid())
  employeeId     String
  employee       User         @relation("EmployeeProduction", fields: [employeeId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sellingPointId String
  sellingPoint   SellingPoint @relation(fields: [sellingPointId], references: [id])
  shiftId        String?
  shift          Shift?       @relation(fields: [shiftId], references: [id])
  shiftCode      String       @default("SANG")
  workDate       DateTime     @db.Date
  quantity       Int          @default(0)
  employeeStatus String       @default("OFFICIAL")

  baseSalary       Decimal @db.Decimal(15, 2)
  bonusAmount      Decimal @default(0) @db.Decimal(15, 2)
  commissionAmount Decimal @default(0) @db.Decimal(15, 2)
  totalSalary      Decimal @db.Decimal(15, 2)

  excludedFromBonus Boolean @default(false) // true nếu ca này có sản phẩm bán giảm giá

  workScheduleId String?      @unique
  workSchedule   WorkSchedule? @relation(fields: [workScheduleId], references: [id])

  isApproved   Boolean  @default(false)
  approvedById String?
  approvedBy   User?    @relation("ProductionApprover", fields: [approvedById], references: [id])

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, workDate(sort: Desc)])
  @@index([employeeId, workDate(sort: Desc)])
  @@index([sellingPointId, workDate(sort: Desc)])
  @@index([isApproved])
  @@map("daily_productions")
}

// ==================== SALARY ====================

model SalaryRecord {
  id         String @id @default(uuid())
  employeeId String
  employee   User   @relation("EmployeeSalary", fields: [employeeId], references: [id])
  branchId   String
  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  periodType   String
  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date

  totalWorkDays  Int @default(0)
  totalShifts    Int @default(0)
  totalQuantity  Int @default(0)

  baseSalary       Decimal @default(0) @db.Decimal(15, 2)
  bonusAmount      Decimal @default(0) @db.Decimal(15, 2)
  commissionAmount Decimal @default(0) @db.Decimal(15, 2)
  allowances       Decimal @default(0) @db.Decimal(15, 2)
  deductions       Decimal @default(0) @db.Decimal(15, 2)
  advanceAmount    Decimal @default(0) @db.Decimal(15, 2)

  grossSalary Decimal @db.Decimal(15, 2)
  netSalary   Decimal @db.Decimal(15, 2)

  status             String  @default("PENDING")
  approvedByBranchId String?
  approvedByBranch   User?   @relation("SalaryApproverBranch", fields: [approvedByBranchId], references: [id])
  approvedByOrgId    String?
  approvedByOrg      User?   @relation("SalaryApproverOrg", fields: [approvedByOrgId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adjustments SalaryAdjustment[]

  @@unique([employeeId, periodStart, periodEnd])
  @@index([branchId, periodStart(sort: Desc)])
  @@index([status])
  @@map("salary_records")
}

model SalaryAdjustment {
  id             String       @id @default(uuid())
  salaryRecordId String
  salaryRecord   SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)
  type           String
  amount         Decimal      @db.Decimal(15, 2)
  reason         String?
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([salaryRecordId])
  @@map("salary_adjustments")
}

// ==================== COSTS ====================

model CostCategory {
  id               String  @id @default(uuid())
  name             String
  type             String
  unit             String
  defaultUnitPrice Decimal @default(0) @db.Decimal(15, 2)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  costRecords CostRecord[]

  @@index([type, isActive])
  @@map("cost_categories")
}

model CostRecord {
  id          String       @id @default(uuid())
  branchId    String
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId  String
  category    CostCategory @relation(fields: [categoryId], references: [id])
  costDate    DateTime     @db.Date
  quantity    Int
  unitPrice   Decimal      @db.Decimal(15, 2)
  totalAmount Decimal      @db.Decimal(18, 2)
  note        String?
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([branchId, costDate(sort: Desc)])
  @@index([categoryId, costDate(sort: Desc)])
  @@map("cost_records")
}

// ==================== AUDIT & PRICE HISTORY ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model PriceHistory {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  costPrice    Decimal  @db.Decimal(15, 2)
  sellingPrice Decimal  @db.Decimal(15, 2)
  changedById  String
  changedBy    User     @relation(fields: [changedById], references: [id])
  changedAt    DateTime @default(now())

  @@index([productId, changedAt(sort: Desc)])
  @@map("price_histories")
}
